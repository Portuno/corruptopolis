# ─── Supabase ────────────────────────────────────────────────────────────
# Project URL (e.g. https://xxxxxxxx.supabase.co)
# Do NOT use /rest/v1 or /auth/v1 suffixes here.
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key (safe to ship to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SERVER ONLY — never expose this to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Gemini ───────────────────────────────────────────────────────
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the model. Defaults to gemini-2.5-flash.
# IMPORTANT: gemini-1.5-flash was retired in 2025 and now returns 404.
GEMINI_MODEL=gemini-2.5-flash

# ─── ElevenLabs ──────────────────────────────────────────────────────────
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional: override the voice id. Defaults to "pNInz6obpgDQGcFmaJgB" (Adam).
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ─── App ─────────────────────────────────────────────────────────────────
# Public URL used for OAuth callbacks (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enable verbose server logs (info|debug). Defaults to "info".
LOG_LEVEL=info
